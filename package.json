{
  "name": "repolens",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Repolens - Understand any GitHub repository in seconds",
  "scripts": {
    "start": "npm start --workspace=backend",
    "dev": "npm run dev --workspace=client",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=client",
    "build:client": "npm run build --workspace=client",
    "install:all": "npm install && npm install --workspace=client && npm install --workspace=backend"
  },
  "workspaces": [
    "client",
    "backend"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "react-icons": "^5.5.0"
  }
}
